{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/drugs",
      "destination": "http://localhost:3001/search"
    },
    {
      "source": "/api/:path*",
      "destination": "http://localhost:3001/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
